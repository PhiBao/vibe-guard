# VibeGuard environment template
#
# Copy to `.env.local` for local development:
#   cp .env.example .env.local
#
# Safety default: VibeGuard is simulation-only. These keys are used only for
# optional read-only account context in the proof card. Do not use keys with
# withdrawal permissions.

# Optional Bitget read-only API credentials.
# Required only if you want the Account + Playbook panel to show live account
# assets, positions, open orders, and recent fills.
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=

# Optional Playbook key detection.
# Current MVP detects that this exists, but metrics still come from the
# documented GetAgent/website flow and should be pasted into the UI as JSON.
PLAYBOOK_API_KEY=

# Optional app metadata for deployment previews.
NEXT_PUBLIC_APP_NAME=VibeGuard
NEXT_PUBLIC_DEMO_MODE=true
